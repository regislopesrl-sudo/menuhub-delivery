generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  DRAFT
  PENDING_CONFIRMATION
  CONFIRMED
  IN_PREPARATION
  READY
  WAITING_PICKUP
  WAITING_DISPATCH
  OUT_FOR_DELIVERY
  DELIVERED
  FINALIZED
  CANCELED
  REFUNDED
}

enum OrderType {
  DELIVERY
  COUNTER
  PICKUP
  TABLE
  COMMAND
  WHATSAPP
  KIOSK
  QR
}

enum TableStatus {
  FREE
  OCCUPIED
  RESERVED
  WAITING_CLOSURE
  BLOCKED
}

enum StockMovementType {
  ENTRY
  EXIT
  ADJUSTMENT
  LOSS
  TRANSFER
  PRODUCTION_CONSUMPTION
  PRODUCTION_OUTPUT
  SALE_CONSUMPTION
  RETURN
}

enum ConversationStatus {
  BOT_ACTIVE
  WAITING_HUMAN
  PAUSED
  CLOSED
}

model User {
  id                            String                 @id @default(uuid())
  name                          String
  email                         String?                @unique
  phone                         String?
  passwordHash                  String
  isActive                      Boolean                @default(true)
  lastLoginAt                   DateTime?
  createdAt                     DateTime               @default(now())
  updatedAt                     DateTime               @updatedAt
  deletedAt                     DateTime?
  roles                         UserRole[]
  refreshTokens                 RefreshToken[]
  assignedWhatsappConversations WhatsappConversation[]
  handledReviews                Review[]
  ordersCreated                 Order[]                @relation("OrderCreatedBy")
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  users       UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String           @id @default(uuid())
  code        String           @unique
  description String?
  createdAt   DateTime         @default(now())
  roles       RolePermission[]
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Company {
  id          String           @id @default(uuid())
  legalName   String
  tradeName   String
  cnpj        String?          @unique
  phone       String?
  whatsapp    String?
  email       String?
  logoUrl     String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  branches    Branch[]
  customers   Customer[]
  categories  Category[]
  products    Product[]
  addonGroups AddonGroup[]
  combos      Combo[]
  stockItems  StockItem[]
  coupons     Coupon[]
  giftCards   GiftCard[]
  orders      Order[]
  settings    CompanySetting[]
  reviews     Review[]
}

model Branch {
  id               String            @id @default(uuid())
  companyId        String
  name             String
  code             String?
  phone            String?
  whatsapp         String?
  email            String?
  city             String?
  state            String?
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  company          Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders           Order[]
  settings         CompanySetting[]
  tables           TableRestaurant[]
  commands         Command[]
  reservations     Reservation[]
  waitlists        Waitlist[]
  couriers         Courier[]
  deliveryAreas    DeliveryArea[]
  productionOrders ProductionOrder[]
}

model CompanySetting {
  id        String  @id @default(uuid())
  companyId String
  branchId  String
  key       String
  value     Json
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch    Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([companyId, branchId, key])
}

model Customer {
  id                    String                 @id @default(uuid())
  companyId             String
  name                  String
  phone                 String?
  whatsapp              String?
  email                 String?
  cpfCnpj               String?
  birthDate             DateTime?
  notes                 String?
  isVip                 Boolean                @default(false)
  isBlocked             Boolean                @default(false)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  deletedAt             DateTime?
  company               Company                @relation(fields: [companyId], references: [id], onDelete: Cascade)
  addresses             CustomerAddress[]
  orders                Order[]
  receivables           AccountsReceivable[]
  commands              Command[]
  reservations          Reservation[]
  waitlists             Waitlist[]
  whatsappConversations WhatsappConversation[]
  loyaltyTransactions   LoyaltyTransaction[]
  reviews               Review[]
}

model CustomerAddress {
  id             String  @id @default(uuid())
  customerId     String
  deliveryAreaId String?
  label          String?
  zipCode        String?
  street         String
  number         String
  complement     String?
  district       String
  city           String
  state          String
  reference      String?
  ibgeCode       String?
  latitude       Float?
  longitude      Float?
  isDefault      Boolean @default(false)

  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  deliveryArea DeliveryArea? @relation(fields: [deliveryAreaId], references: [id])
  orders       Order[]

  @@index([customerId])
}

model DeliveryArea {
  id               String            @id @default(uuid())
  branchId         String
  name             String
  zipCodeStart     String
  zipCodeEnd       String
  deliveryFee      Decimal           @default(0) @db.Decimal(12, 2)
  estimatedMinutes Int               @default(0)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  branch           Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  addresses        CustomerAddress[]
  orders           Order[]
}

model Category {
  id        String    @id @default(uuid())
  companyId String
  name      String
  sortOrder Int       @default(0)
  isActive  Boolean   @default(true)
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products  Product[]
}

model Product {
  id                String              @id @default(uuid())
  companyId         String
  categoryId        String?
  name              String
  description       String?
  sku               String?
  salePrice         Decimal             @db.Decimal(12, 2)
  promotionalPrice  Decimal?            @db.Decimal(12, 2)
  costPrice         Decimal             @default(0) @db.Decimal(12, 2)
  prepTimeMinutes   Int                 @default(0)
  imageUrl          String?
  isActive          Boolean             @default(true)
  isFeatured        Boolean             @default(false)
  controlsStock     Boolean             @default(false)
  allowNotes        Boolean             @default(true)
  availableDelivery Boolean             @default(true)
  availableCounter  Boolean             @default(true)
  availableTable    Boolean             @default(true)
  sortOrder         Int                 @default(0)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  deletedAt         DateTime?
  company           Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  category          Category?           @relation(fields: [categoryId], references: [id])
  addonLinks        ProductAddonGroup[]
  comboItems        ComboItem[]
}

model AddonGroup {
  id            String              @id @default(uuid())
  companyId     String
  name          String
  minSelect     Int                 @default(0)
  maxSelect     Int                 @default(1)
  required      Boolean             @default(false)
  allowMultiple Boolean             @default(false)
  company       Company             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items         AddonItem[]
  productLinks  ProductAddonGroup[]
}

model AddonItem {
  id        String     @id @default(uuid())
  groupId   String
  name      String
  price     Decimal    @db.Decimal(12, 2)
  isActive  Boolean    @default(true)
  sortOrder Int        @default(0)
  group     AddonGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model ProductAddonGroup {
  id           String     @id @default(uuid())
  productId    String
  addonGroupId String
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  addonGroup   AddonGroup @relation(fields: [addonGroupId], references: [id], onDelete: Cascade)

  @@unique([productId, addonGroupId])
}

model Combo {
  id          String      @id @default(uuid())
  companyId   String
  name        String
  description String?
  price       Decimal     @default(0) @db.Decimal(12, 2)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items       ComboItem[]
}

model ComboItem {
  id        String  @id @default(uuid())
  comboId   String
  productId String
  quantity  Decimal @default(1) @db.Decimal(12, 3)
  combo     Combo   @relation(fields: [comboId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@unique([comboId, productId])
}

model TableRestaurant {
  id           String        @id @default(uuid())
  branchId     String
  name         String
  capacity     Int           @default(1)
  status       TableStatus   @default(FREE)
  qrCode       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  branch       Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  orders       Order[]
  reservations Reservation[]
  commands     Command[]
}

model Command {
  id                String           @id @default(uuid())
  branchId          String
  customerId        String?
  code              String
  status            String           @default("open")
  openedAt          DateTime         @default(now())
  closedAt          DateTime?
  createdAt         DateTime         @default(now())
  branch            Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer          Customer?        @relation(fields: [customerId], references: [id])
  orders            Order[]
  tableRestaurant   TableRestaurant? @relation(fields: [tableRestaurantId], references: [id])
  tableRestaurantId String?

  @@unique([branchId, code])
  @@index([branchId])
}

model Reservation {
  id            String           @id @default(uuid())
  branchId      String
  customerId    String?
  tableId       String?
  guestName     String
  guestPhone    String?
  guestCount    Int
  reservationAt DateTime
  status        String           @default("booked")
  notes         String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  branch        Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer      Customer?        @relation(fields: [customerId], references: [id])
  table         TableRestaurant? @relation(fields: [tableId], references: [id])
}

model Waitlist {
  id         String    @id @default(uuid())
  branchId   String
  customerId String?
  guestName  String
  guestPhone String?
  guestCount Int
  status     String    @default("waiting")
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  branch     Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer   Customer? @relation(fields: [customerId], references: [id])
}

model Order {
  id                   String      @id @default(uuid())
  companyId            String
  branchId             String
  customerId           String?
  tableId              String?
  commandId            String?
  deliveryAreaId       String?
  customerAddressId    String?
  orderNumber          String
  orderType            OrderType
  channel              String
  status               OrderStatus
  subtotal             Decimal     @default(0) @db.Decimal(12, 2)
  discountAmount       Decimal     @default(0) @db.Decimal(12, 2)
  deliveryFee          Decimal     @default(0) @db.Decimal(12, 2)
  extraFee             Decimal     @default(0) @db.Decimal(12, 2)
  totalAmount          Decimal     @default(0) @db.Decimal(12, 2)
  notes                String?
  internalNotes        String?
  cancellationReason   String?
  createdById          String?
  confirmedAt          DateTime?
  preparationStartedAt DateTime?
  readyAt              DateTime?
  dispatchedAt         DateTime?
  deliveredAt          DateTime?
  finalizedAt          DateTime?
  canceledAt           DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  deletedAt            DateTime?

  company             Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch              Branch               @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer            Customer?            @relation(fields: [customerId], references: [id], onDelete: SetNull)
  table               TableRestaurant?     @relation(fields: [tableId], references: [id], onDelete: SetNull)
  deliveryArea        DeliveryArea?        @relation(fields: [deliveryAreaId], references: [id], onDelete: SetNull)
  customerAddress     CustomerAddress?     @relation(fields: [customerAddressId], references: [id], onDelete: SetNull)
  command             Command?             @relation(fields: [commandId], references: [id], onDelete: SetNull)
  createdBy           User?                @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items               OrderItem[]
  payments            OrderPayment[]
  statusLogs          OrderStatusLog[]
  receivables         AccountsReceivable[]
  courierDeliveries   CourierDelivery[]
  loyaltyTransactions LoyaltyTransaction[]
  reviews             Review[]

  @@unique([branchId, orderNumber])
  @@index([companyId, branchId])
  @@index([customerId])
  @@index([deliveryAreaId])
  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id                      String           @id @default(uuid())
  orderId                 String
  productId               String?
  productNameSnapshot     String
  quantity                Decimal          @default(1) @db.Decimal(12, 3)
  unitPrice               Decimal          @default(0) @db.Decimal(12, 2)
  costSnapshot            Decimal          @default(0) @db.Decimal(12, 2)
  theoreticalCostSnapshot Decimal?         @db.Decimal(12, 2)
  totalPrice              Decimal          @default(0) @db.Decimal(12, 2)
  notes                   String?
  sentToKds               Boolean          @default(false)
  status                  String           @default("pending")
  createdAt               DateTime         @default(now())
  order                   Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  addons                  OrderItemAddon[]
}

model OrderItemAddon {
  id            String    @id @default(uuid())
  orderItemId   String
  addonItemId   String?
  nameSnapshot  String
  priceSnapshot Decimal   @default(0) @db.Decimal(12, 2)
  quantity      Decimal   @default(1) @db.Decimal(12, 3)
  orderItem     OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
}

model OrderPayment {
  id                   String   @id @default(uuid())
  orderId              String
  paymentMethod        String
  amount               Decimal  @db.Decimal(12, 2)
  status               String   @default("paid")
  transactionReference String?
  paidAt               DateTime @default(now())
  order                Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderStatusLog {
  id             String   @id @default(uuid())
  orderId        String
  previousStatus String?
  newStatus      String
  notes          String?
  createdAt      DateTime @default(now())
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model StockItem {
  id                   String                @id @default(uuid())
  companyId            String
  categoryId           String?
  supplierId           String?
  name                 String
  code                 String?
  purchaseUnit         String?
  stockUnit            String?
  productionUnit       String?
  conversionFactor     Decimal               @default(1) @db.Decimal(14, 6)
  currentQuantity      Decimal               @default(0) @db.Decimal(14, 3)
  minimumQuantity      Decimal               @default(0) @db.Decimal(14, 3)
  reorderPoint         Decimal               @default(0) @db.Decimal(14, 3)
  averageCost          Decimal               @default(0) @db.Decimal(12, 4)
  lastCost             Decimal               @default(0) @db.Decimal(12, 4)
  standardCost         Decimal               @default(0) @db.Decimal(12, 4)
  leadTimeDays         Int                   @default(0)
  controlsBatch        Boolean               @default(false)
  controlsExpiry       Boolean               @default(false)
  requiresFefo         Boolean               @default(false)
  isPerishable         Boolean               @default(false)
  isFractionable       Boolean               @default(false)
  isCritical           Boolean               @default(false)
  isHighTurnover       Boolean               @default(false)
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  company              Company               @relation(fields: [companyId], references: [id], onDelete: Cascade)
  batches              StockBatch[]
  movements            StockMovement[]
  purchaseRequestItems PurchaseRequestItem[]
  purchaseOrderItems   PurchaseOrderItem[]
  goodsReceiptItems    GoodsReceiptItem[]
  productionOrders     ProductionOrder[]
}

model StockBatch {
  id                String             @id @default(uuid())
  stockItemId       String
  supplierId        String?
  batchNumber       String?
  manufactureDate   DateTime?
  receivedDate      DateTime?
  openedDate        DateTime?
  expiryDate        DateTime?
  useUntilDate      DateTime?
  initialQuantity   Decimal            @default(0) @db.Decimal(14, 3)
  availableQuantity Decimal            @default(0) @db.Decimal(14, 3)
  unitCost          Decimal            @default(0) @db.Decimal(12, 4)
  status            String             @default("available")
  sanitaryNotes     String?
  createdAt         DateTime           @default(now())
  stockItem         StockItem          @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  movements         StockMovement[]
  goodsReceiptItems GoodsReceiptItem[]
}

model StockMovement {
  id                   String            @id @default(uuid())
  stockItemId          String
  batchId              String?
  movementType         StockMovementType
  movementTypeDetailed String?
  sourceModule         String?
  sourceId             String?
  quantity             Decimal           @db.Decimal(14, 3)
  unitCost             Decimal           @default(0) @db.Decimal(12, 4)
  totalCost            Decimal           @default(0) @db.Decimal(12, 2)
  reasonCode           String?
  notes                String?
  createdAt            DateTime          @default(now())
  stockItem            StockItem         @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  batch                StockBatch?       @relation(fields: [batchId], references: [id])
}

model PurchaseRequest {
  id        String                @id @default(uuid())
  branchId  String
  notes     String?
  createdAt DateTime              @default(now())
  items     PurchaseRequestItem[]
}

model PurchaseRequestItem {
  id                String          @id @default(uuid())
  purchaseRequestId String
  stockItemId       String
  quantity          Decimal         @db.Decimal(14, 3)
  notes             String?
  purchaseRequest   PurchaseRequest @relation(fields: [purchaseRequestId], references: [id], onDelete: Cascade)
  stockItem         StockItem       @relation(fields: [stockItemId], references: [id])
}

model Supplier {
  id              String            @id @default(uuid())
  companyId       String
  name            String
  document        String?
  phone           String?
  email           String?
  notes           String?
  createdAt       DateTime          @default(now())
  purchaseOrders  PurchaseOrder[]
  goodsReceipts   GoodsReceipt[]
  accountsPayable AccountsPayable[]
}

model PurchaseOrder {
  id                   String              @id @default(uuid())
  branchId             String
  supplierId           String
  status               String              @default("draft")
  expectedDeliveryDate DateTime?
  totalAmount          Decimal             @default(0) @db.Decimal(12, 2)
  notes                String?
  createdAt            DateTime            @default(now())
  supplier             Supplier            @relation(fields: [supplierId], references: [id])
  items                PurchaseOrderItem[]
  goodsReceipts        GoodsReceipt[]
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  purchaseOrderId String
  stockItemId     String
  quantity        Decimal       @db.Decimal(14, 3)
  unitCost        Decimal       @db.Decimal(12, 4)
  totalCost       Decimal       @db.Decimal(12, 2)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  stockItem       StockItem     @relation(fields: [stockItemId], references: [id])
}

model GoodsReceipt {
  id              String             @id @default(uuid())
  purchaseOrderId String?
  supplierId      String
  invoiceNumber   String?
  invoiceKey      String?
  status          String             @default("pending")
  receivedAt      DateTime?
  createdAt       DateTime           @default(now())
  purchaseOrder   PurchaseOrder?     @relation(fields: [purchaseOrderId], references: [id])
  supplier        Supplier           @relation(fields: [supplierId], references: [id])
  items           GoodsReceiptItem[]
}

model GoodsReceiptItem {
  id               String       @id @default(uuid())
  goodsReceiptId   String
  stockItemId      String
  batchId          String?
  orderedQuantity  Decimal?     @db.Decimal(14, 3)
  receivedQuantity Decimal      @db.Decimal(14, 3)
  unitCost         Decimal      @db.Decimal(12, 4)
  hasDivergence    Boolean      @default(false)
  divergenceNotes  String?
  goodsReceipt     GoodsReceipt @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  stockItem        StockItem    @relation(fields: [stockItemId], references: [id])
  batch            StockBatch?  @relation(fields: [batchId], references: [id])
}

model CashRegister {
  id             String    @id @default(uuid())
  branchId       String
  openingBalance Decimal   @default(0) @db.Decimal(12, 2)
  closingBalance Decimal?  @db.Decimal(12, 2)
  status         String    @default("open")
  openedAt       DateTime  @default(now())
  closedAt       DateTime?
}

model CashMovement {
  id             String   @id @default(uuid())
  cashRegisterId String
  orderId        String?
  movementType   String
  category       String?
  amount         Decimal  @db.Decimal(12, 2)
  notes          String?
  createdAt      DateTime @default(now())
}

model AccountsPayable {
  id              String    @id @default(uuid())
  branchId        String
  supplierId      String?
  description     String
  amount          Decimal   @db.Decimal(12, 2)
  dueDate         DateTime
  status          String    @default("pending")
  purchaseOrderId String?
  createdAt       DateTime  @default(now())
  supplier        Supplier? @relation(fields: [supplierId], references: [id])
}

model AccountsReceivable {
  id          String    @id @default(uuid())
  branchId    String
  customerId  String?
  orderId     String?
  description String
  amount      Decimal   @db.Decimal(12, 2)
  dueDate     DateTime?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  customer    Customer? @relation(fields: [customerId], references: [id])
  order       Order?    @relation(fields: [orderId], references: [id])
}

model Coupon {
  id                 String    @id @default(uuid())
  companyId          String
  code               String    @unique
  discountType       String
  discountValue      Decimal   @db.Decimal(12, 2)
  minimumOrderAmount Decimal?  @db.Decimal(12, 2)
  maxUses            Int?
  perCustomerLimit   Int?
  startsAt           DateTime?
  endsAt             DateTime?
  firstOrderOnly     Boolean   @default(false)
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  company            Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model ProductionOrder {
  id              String    @id @default(uuid())
  branchId        String
  stockItemId     String
  plannedQuantity Decimal   @db.Decimal(14, 3)
  actualQuantity  Decimal?  @db.Decimal(14, 3)
  status          String    @default("planned")
  startedAt       DateTime?
  finishedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  branch          Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  stockItem       StockItem @relation(fields: [stockItemId], references: [id])
}

model Courier {
  id              String            @id @default(uuid())
  branchId        String
  name            String
  phone           String?
  vehicleType     String?
  vehiclePlate    String?
  document        String?
  commissionType  String?
  commissionValue Decimal?          @db.Decimal(12, 2)
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  branch          Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  deliveries      CourierDelivery[]
}

model CourierDelivery {
  id               String    @id @default(uuid())
  orderId          String
  courierId        String
  assignedAt       DateTime  @default(now())
  outForDeliveryAt DateTime?
  deliveredAt      DateTime?
  failedAt         DateTime?
  failedReason     String?
  createdAt        DateTime  @default(now())
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courier          Courier   @relation(fields: [courierId], references: [id], onDelete: Cascade)
}

model WhatsappConversation {
  id           String             @id @default(uuid())
  customerId   String?
  assignedToId String?
  phone        String?
  status       ConversationStatus @default(BOT_ACTIVE)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  customer     Customer?          @relation(fields: [customerId], references: [id])
  assignedTo   User?              @relation(fields: [assignedToId], references: [id])
  messages     WhatsappMessage[]
}

model WhatsappMessage {
  id             String               @id @default(uuid())
  conversationId String
  direction      String
  messageType    String               @default("text")
  content        String
  sentAt         DateTime             @default(now())
  conversation   WhatsappConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

model LoyaltyTransaction {
  id              String   @id @default(uuid())
  customerId      String
  orderId         String?
  transactionType String
  points          Int
  description     String?
  createdAt       DateTime @default(now())
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order           Order?   @relation(fields: [orderId], references: [id])
}

model GiftCard {
  id             String    @id @default(uuid())
  companyId      String
  code           String    @unique
  initialBalance Decimal   @db.Decimal(12, 2)
  currentBalance Decimal   @db.Decimal(12, 2)
  expiresAt      DateTime?
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  company        Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Review {
  id                String    @id @default(uuid())
  companyId         String
  customerId        String?
  orderId           String?
  handledById       String?
  channel           String    @default("manual")
  rating            Int
  title             String?
  comment           String?
  authorName        String?
  authorContact     String?
  status            String    @default("new")
  sentiment         String?
  internalNotes     String?
  responseText      String?
  responseAt        DateTime?
  reviewAt          DateTime  @default(now())
  handledAt         DateTime?
  externalReference String?
  metadata          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  company           Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer          Customer? @relation(fields: [customerId], references: [id])
  order             Order?    @relation(fields: [orderId], references: [id])
  handledBy         User?     @relation(fields: [handledById], references: [id])

  @@index([companyId, status])
  @@index([customerId])
  @@index([orderId])
}

{
  "name": "sistema-delivery-futuro",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:backend": "npm run start:dev --workspace @delivery-futuro/backend",
    "dev:frontend": "npm run dev --workspace @delivery-futuro/frontend",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace @delivery-futuro/backend",
    "db:push": "npm run db:push --workspace @delivery-futuro/backend",
    "seed": "npm run seed --workspace @delivery-futuro/backend",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.4.2"
  },
  "dependencies": {
    "ioredis": "^5.10.0"
  }
}
